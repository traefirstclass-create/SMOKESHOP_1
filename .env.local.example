# Copy this file to .env.local for local development, and add the same
# values in your Vercel project's Settings → Environment Variables for
# production/preview deploys.

# --- Supabase (product catalog, orders, auth, and the compliance system —
# state registrations, audit log, staff accounts) ---
# Create a free project at https://supabase.com, then run supabase/schema.sql
# and supabase/seed.sql in its SQL editor. Find these values under
# Project Settings → API. See README.md and COMPLIANCE.md for staff account
# setup (needed to log into /admin).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — secret, server-only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Authorize.Net (payments) ---
# Create a free sandbox account at https://developer.authorize.net to get
# sandbox credentials for testing. Going live requires an approved
# Authorize.Net production merchant account (smoke/vape/tobacco shops
# typically need underwriting from a high-risk-friendly processor/bank —
# see README.md for details).
NEXT_PUBLIC_AUTHORIZE_NET_ENVIRONMENT=sandbox
NEXT_PUBLIC_AUTHORIZE_NET_API_LOGIN_ID=
NEXT_PUBLIC_AUTHORIZE_NET_CLIENT_KEY=
# Transaction key — secret, server-only, never exposed to the browser.
AUTHORIZE_NET_TRANSACTION_KEY=
